# Copy this file to .env locally, or configure the same variable in your host.
# The app does not commit real credentials.
DATABASE_URL=postgresql+psycopg2://o1:o1@localhost:55432/o1

# Frontend override when the API is not on localhost:8000.
# Leave blank for same-origin Next/Vercel route handlers, or set http://localhost:8000 for FastAPI.
NEXT_PUBLIC_API_URL=

# Optional server-side override for Next.js route handlers (recommended on Vercel).
# Set this to your public FastAPI URL, e.g. https://api.your-domain.com
FASTAPI_BACKEND_URL=

# Comma-separated browser origins allowed to call FastAPI.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: forward POST /chat to any model/router backend that speaks this contract.
# If unset, FastAPI returns a local stub response with the same response shape.
CHAT_BACKEND_URL=

# Track 1 router settings. Keep real keys in local .env or Vercel env, never source.
LOCAL_MODEL_NAME=gemma3:1b-it-qat
LOCAL_MODEL_API_URL=http://127.0.0.1:11434/api/chat
VLLM_BASE_URL=
VLLM_API_KEY=
VLLM_LOCAL_MODEL_SIZE=large
PREFER_VLLM_LOCAL=1
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=
ALLOWED_MODELS=
FIREWORKS_MODEL=
CLOUD_MODEL_NAME=Fireworks

# T1 multi-stage local harness. All inference stays on the configured local
# model; these settings do not select, download, or host the model itself.
LOCAL_T1_MULTISTEP_ENABLED=1
LOCAL_T1_REQUEST_DEADLINE_S=26
LOCAL_T1_ANALYZER_MAX_TOKENS=384
LOCAL_T1_REASONING_MAX_TOKENS=512
LOCAL_T1_ANSWER_MAX_TOKENS=384
LOCAL_T1_VALIDATOR_MAX_TOKENS=256
LOCAL_T1_REPAIR_MAX_TOKENS=384
LOCAL_T1_MAX_REPAIRS=2
LOCAL_HARNESS_LOG_PATH=logs.jsonl

# Optional web grounding. Disabled by default because grader network access is
# not guaranteed. Configure an endpoint and key only in runtime environment.
LOCAL_WEB_SEARCH_ENABLED=0
LOCAL_WEB_SEARCH_ENDPOINT=
LOCAL_WEB_SEARCH_API_KEY=
LOCAL_WEB_SEARCH_TIMEOUT_S=3
LOCAL_WEB_SEARCH_RESULTS=3

# Sandboxed generated-Python execution limits.
LOCAL_PYTHON_TIMEOUT_S=2
LOCAL_PYTHON_MEMORY_MB=128
LOCAL_PYTHON_OUTPUT_BYTES=8192
