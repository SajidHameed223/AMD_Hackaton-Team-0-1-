# Copy this file to .env for local development. The Docker image does NOT
# read .env — it reads all config from environment variables injected by the
# harness at grading time.

# ---------------------------------------------------------------------------
# T0 / T1 local runtime (0 Fireworks tokens)
# ---------------------------------------------------------------------------
LOCAL_T1_BACKEND=ollama              # ollama = HTTP to local Ollama; else torch
OLLAMA_URL=http://127.0.0.1:11434/api/chat
LOCAL_MODEL=gemma4:2b                # Ollama model tag created at build time

# Non-ollama T1 path (optional, needs requirements.txt installed):
MODEL_NAME=                          # HuggingFace ID for torch-based T1
LOCAL_USE_4BIT=1

# T1 multi-stage harness tuning (all inference stays local):
LOCAL_T1_MULTISTEP_ENABLED=1
LOCAL_T1_REQUEST_DEADLINE_S=28
LOCAL_T1_ANALYZER_MAX_TOKENS=64
LOCAL_T1_ANSWER_MAX_TOKENS=384
LOCAL_T1_VALIDATOR_MAX_TOKENS=48
LOCAL_T1_REPAIR_MAX_TOKENS=384
LOCAL_T1_MAX_REPAIRS=2
LOCAL_HARNESS_LOG_PATH=logs.jsonl

# Sandboxed generated-Python execution limits:
LOCAL_PYTHON_TIMEOUT_S=2
LOCAL_PYTHON_MEMORY_MB=128
LOCAL_PYTHON_OUTPUT_BYTES=8192

# ---------------------------------------------------------------------------
# T2 Fireworks (paid tokens — OFF by default for  scoring)
# Set ENABLE_T2=1 to opt into the cloud fallback path.
# ---------------------------------------------------------------------------
ENABLE_T2=0
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=
ALLOWED_MODELS=